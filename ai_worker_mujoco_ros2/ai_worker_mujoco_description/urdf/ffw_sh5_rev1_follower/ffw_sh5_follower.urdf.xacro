<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="ffw_sh5_follower">
  <xacro:property name="meshes_file_direction" value="package://ai_worker_mujoco_description/meshes/$(arg model)" />
  <xacro:property name="swerve_meshes_dir" value="package://ai_worker_mujoco_description/meshes/common/follower/swerve" />
  <xacro:arg name="prefix" default="" />
  <xacro:arg name="model" default="ffw_sh5_rev1_follower" />

  <xacro:include filename="$(find ai_worker_mujoco_description)/urdf/common/follower/ffw_follower_body.xacro" />

  <xacro:include filename="$(find ai_worker_mujoco_description)/urdf/common/hx5_d20/hx5_d20_left.urdf.xacro" />

  <xacro:include filename="$(find ai_worker_mujoco_description)/urdf/common/hx5_d20/hx5_d20_right.urdf.xacro" />


  <link name="$(arg prefix)base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="${swerve_meshes_dir}/base_mobile_assy.stl" scale="0.001 0.001 0.001" />
      </geometry>
      <material name="silver">
        <color rgba="0.75 0.75 0.75 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="${swerve_meshes_dir}/base_mobile_assy.stl" scale="0.001 0.001 0.001" />
      </geometry>
    </collision>
    <inertial>
       <!-- Center the base inertia to reduce biased yaw under straight motion -->
       <origin xyz="0 0 0" />
       <mass value="3.598943900e+01" />
       <inertia ixx="1.725473500" ixy="6.471795500e-06" ixz="1.890204600e-05"
       iyy="3.983747500" iyz="1.716567300e-05"
       izz="2.846139500" />
    </inertial>
  </link>

  <joint name="$(arg prefix)lidar_l_joint" type="fixed">
    <parent link="$(arg prefix)base_link"/>
    <child link="$(arg prefix)lidar_l_link"/>
    <origin xyz="-0.111881 0.240 0.34432" rpy="0 0 1.57079632679"/>
  </joint>
  <link name="$(arg prefix)lidar_l_link">
  </link>

  <joint name="$(arg prefix)lidar_r_joint" type="fixed">
    <parent link="$(arg prefix)base_link"/>
    <child link="$(arg prefix)lidar_r_link"/>
    <origin xyz="-0.111881 -0.240 0.34432" rpy="0 0 -1.57079632679"/>
  </joint>
  <link name="$(arg prefix)lidar_r_link">
  </link>

  <joint name="$(arg prefix)imu_joint" type="fixed">
    <parent link="$(arg prefix)base_link"/>
    <child link="$(arg prefix)imu_link"/>
    <origin xyz="-0.1464 0.0 0.26" rpy="0 0 0"/>
  </joint>
  <link name="$(arg prefix)imu_link">
  </link>

  <link name="$(arg prefix)lift_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="${swerve_meshes_dir}/lift_link.stl" scale="0.001 0.001 0.001" />
      </geometry>
      <material name="silver">
        <color rgba="0.75 0.75 0.75 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="${swerve_meshes_dir}/lift_link.stl" scale="0.001 0.001 0.001" />
      </geometry>
    </collision>
    <inertial>
       <origin xyz="-1.286987800e-01 -1.604580800e-05 8.945601700e-01" />
       <mass value="17.9" />
       <inertia ixx="0.0100947" ixy="-0.0000000356" ixz="0.0012131"
                iyy="0.0102705" iyz="0.0000000702"
                izz="0.0001971" />
    </inertial>
  </link>
  <joint name="$(arg prefix)lift_fixed_joint" type="fixed">
    <parent link="$(arg prefix)base_link"/>
    <child link="$(arg prefix)lift_link"/>
    <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
  </joint>

  <xacro:ffw_follower_body parent="$(arg prefix)base_link" prefix="$(arg prefix)">
    <origin xyz="-0.0199 0 1.4316" rpy="0 0 0" />
  </xacro:ffw_follower_body>

  <xacro:hx5_d20_left parent="$(arg prefix)arm_l_link7" prefix="$(arg prefix)">
    <origin xyz="0 0 -0.078" rpy="0 3.14159265359 1.5708"/>
  </xacro:hx5_d20_left>

  <xacro:hx5_d20_right parent="$(arg prefix)arm_r_link7" prefix="$(arg prefix)">
    <origin xyz="0 0 -0.078" rpy="0 3.14159265359 -1.5708"/>
  </xacro:hx5_d20_right>

  <joint name="$(arg prefix)left_wheel_steer_joint" type="revolute">
      <parent link="$(arg prefix)base_link"/>
      <child link="$(arg prefix)left_wheel_steer_link"/>
      <origin xyz="0.1371 0.2554 0.27555" rpy="0 0 0"/>
      <axis xyz="0 0 1" />
      <limit velocity="9999.0" effort="9999.0" lower="${-pi*6.0}" upper="${pi*6.0}" />
  </joint>
  <link name="$(arg prefix)left_wheel_steer_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="${swerve_meshes_dir}/left_wheel_steer_link.stl" scale="0.001 0.001 0.001" />
      </geometry>
      <material name="silver">
        <color rgba="0.75 0.75 0.75 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="${swerve_meshes_dir}/left_wheel_steer_link.stl" scale="0.001 0.001 0.001" />
      </geometry>
    </collision>
    <inertial>
       <origin xyz="9.802769300e-03 -5.471240900e-02 -1.376533800e-01" />
       <mass value="7.550951000e-01" />
       <inertia ixx="2.797326600e-03" ixy="-3.290807800e-05" ixz="-1.950671800e-04"
       iyy="3.582264900e-03" iyz="-2.853290700e-04"
       izz="1.683594000e-03" />
    </inertial>
  </link>
  <joint name="$(arg prefix)left_wheel_drive_joint" type="continuous">
      <parent link="$(arg prefix)left_wheel_steer_link"/>
      <child link="$(arg prefix)left_wheel_drive_link"/>
      <origin xyz="0 0 -0.18905" rpy="0 0 0"/>
      <axis xyz="0 1 0" />
      <limit velocity="9999.0" effort="9999.0"/>
  </joint>
  <link name="$(arg prefix)left_wheel_drive_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="${swerve_meshes_dir}/left_wheel_drive_link.stl" scale="0.001 0.001 0.001" />
      </geometry>
      <material name="silver">
        <color rgba="0.75 0.75 0.75 1"/>
      </material>
    </visual>
    <!-- <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="${swerve_meshes_dir}/left_wheel_drive_link.stl" scale="0.001 0.001 0.001" />
      </geometry>
    </collision> -->
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.0865" length="0.05"/>
      </geometry>
    </collision>
    <inertial>
       <origin xyz="0.000000000e+00 -1.499601700e-03 0.000000000e+00" />
       <mass value="3.795460500e+00" />
       <inertia ixx="7.187881500e-03" ixy="0.000000000e+00" ixz="0.000000000e+00"
       iyy="1.156399900e-02" iyz="0.000000000e+00"
       izz="7.187977000e-03" />
    </inertial>
  </link>

  <joint name="$(arg prefix)right_wheel_steer_joint" type="revolute">
      <parent link="$(arg prefix)base_link"/>
      <child link="$(arg prefix)right_wheel_steer_link"/>
      <origin xyz="0.1371 -0.2554 0.27555" rpy="0 0 0"/>
      <axis xyz="0 0 1" />
      <limit velocity="9999.0" effort="9999.0" lower="${-pi*6.0}" upper="${pi*6.0}" />
  </joint>
  <link name="$(arg prefix)right_wheel_steer_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="${swerve_meshes_dir}/right_wheel_steer_link.stl" scale="0.001 0.001 0.001" />
      </geometry>
      <material name="silver">
        <color rgba="0.75 0.75 0.75 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="${swerve_meshes_dir}/right_wheel_steer_link.stl" scale="0.001 0.001 0.001" />
      </geometry>
    </collision>
    <inertial>
       <origin xyz="9.802728600e-03 5.471240900e-02 -1.376533400e-01" />
       <mass value="7.550951000e-01" />
       <inertia ixx="2.797322900e-03" ixy="3.290833300e-05" ixz="-1.950642500e-04"
       iyy="3.582262300e-03" iyz="2.853288400e-04"
       izz="1.683595100e-03" />
    </inertial>
  </link>
  <joint name="$(arg prefix)right_wheel_drive_joint" type="continuous">
      <parent link="$(arg prefix)right_wheel_steer_link"/>
      <child link="$(arg prefix)right_wheel_drive_link"/>
      <origin xyz="0 0 -0.18905" rpy="0 0 0"/>
      <axis xyz="0 1 0" />
      <limit velocity="9999.0" effort="9999.0"/>
  </joint>
  <link name="$(arg prefix)right_wheel_drive_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="${swerve_meshes_dir}/right_wheel_drive_link.stl" scale="0.001 0.001 0.001" />
      </geometry>
      <material name="silver">
        <color rgba="0.75 0.75 0.75 1"/>
      </material>
    </visual>
    <!-- <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="${swerve_meshes_dir}/right_wheel_drive_link.stl" scale="0.001 0.001 0.001" />
      </geometry>
    </collision> -->
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.0865" length="0.05"/>
      </geometry>
    </collision>
    <inertial>
       <origin xyz="0.000000000e+00 1.499601700e-03 0.000000000e+00" />
       <mass value="3.795460500e+00" />
       <inertia ixx="7.187881500e-03" ixy="0.000000000e+00" ixz="0.000000000e+00"
       iyy="1.156399900e-02" iyz="0.000000000e+00"
       izz="7.187977000e-03" />
    </inertial>
  </link>

  <joint name="$(arg prefix)rear_wheel_steer_joint" type="revolute">
      <parent link="$(arg prefix)base_link"/>
      <child link="$(arg prefix)rear_wheel_steer_link"/>
      <origin xyz="-0.2899 0 0.27555" rpy="0 0 0"/>
      <axis xyz="0 0 1" />
      <limit velocity="9999.0" effort="9999.0" lower="${-pi*6.0}" upper="${pi*6.0}" />
  </joint>
  <link name="$(arg prefix)rear_wheel_steer_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="${swerve_meshes_dir}/rear_wheel_steer_link.stl" scale="0.001 0.001 0.001" />
      </geometry>
      <material name="silver">
        <color rgba="0.75 0.75 0.75 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="${swerve_meshes_dir}/rear_wheel_steer_link.stl" scale="0.001 0.001 0.001" />
      </geometry>
    </collision>
    <inertial>
       <origin xyz="9.802728600e-03 5.471240900e-02 -1.376533400e-01" />
       <mass value="7.550951000e-01" />
       <inertia ixx="2.797322900e-03" ixy="3.290833300e-05" ixz="-1.950642500e-04"
       iyy="3.582262300e-03" iyz="2.853288400e-04"
       izz="1.683595100e-03" />
    </inertial>
  </link>
  <joint name="$(arg prefix)rear_wheel_drive_joint" type="continuous">
      <parent link="$(arg prefix)rear_wheel_steer_link"/>
      <child link="$(arg prefix)rear_wheel_drive_link"/>
      <origin xyz="0 0 -0.18905" rpy="0 0 0"/>
      <axis xyz="0 1 0" />
      <limit velocity="9999.0" effort="9999.0"/>
  </joint>
  <link name="$(arg prefix)rear_wheel_drive_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="${swerve_meshes_dir}/rear_wheel_drive_link.stl" scale="0.001 0.001 0.001" />
      </geometry>
      <material name="silver">
        <color rgba="0.75 0.75 0.75 1"/>
      </material>
    </visual>
    <!-- <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="${swerve_meshes_dir}/rear_wheel_drive_link.stl" scale="0.001 0.001 0.001" />
      </geometry>
    </collision> -->
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.0865" length="0.05"/>
      </geometry>
    </collision>
    <inertial>
       <origin xyz="0.000000000e+00 1.499601700e-03 0.000000000e+00" />
       <mass value="3.795460500e+00" />
       <inertia ixx="7.187881500e-03" ixy="0.000000000e+00" ixz="0.000000000e+00"
       iyy="1.156399900e-02" iyz="0.000000000e+00"
       izz="7.187977000e-03" />
    </inertial>
  </link>

</robot>
